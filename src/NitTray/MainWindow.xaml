<ui:FluentWindow x:Class="NitTray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:NitTray.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NitTray"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="580" Height="640" MinWidth="480" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ShowInTaskbar="True"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <ui:FluentWindow.Resources>
        <!-- A caption-style read-only TextBox used for serial numbers so the value
             is selectable/copyable. The minimal template (just the content host)
             strips the default TextBox border and inner inset, so the text lines
             up exactly with the product-name TextBlock above it. -->
        <Style x:Key="SerialTextBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="NitTray">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon-32.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="18,8,18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <ui:TextBlock Text="Displays" FontTypography="Title"/>
                    <ui:TextBlock Text="Adjust brightness for supported Apple displays."
                                  FontTypography="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ProgressRing Width="22" Height="22" IsIndeterminate="True" Margin="0,0,10,0"
                                     Visibility="{Binding LoadingVisibility}"/>
                    <ui:Button Content="Refresh" Command="{Binding RefreshCommand}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ArrowClockwise24"/>
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!-- Driver setup prompt -->
            <ui:Card Grid.Row="1" Margin="0,14,0,0" Visibility="{Binding DriverSetupVisibility}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Identity (mirrors a connected display card) -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                Margin="0,0,14,0" VerticalAlignment="Top"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="24"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock Text="{Binding DriverSetupProductName}" FontTypography="BodyStrong"/>
                            <TextBox Text="{Binding DriverSetupSerial, Mode=OneWay}"
                                     Style="{StaticResource SerialTextBox}" IsTabStop="False"
                                     Margin="-2,2,0,0"/>
                        </StackPanel>

                        <ui:Button Grid.Column="2" Content="Set up display"
                                   Appearance="Primary" VerticalAlignment="Center" Margin="14,0,0,0"
                                   Command="{Binding SetUpDriverCommand}"
                                   Visibility="{Binding SetUpButtonVisibility}"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                    Margin="14,0,0,0" Visibility="{Binding InstallingVisibility}">
                            <ui:ProgressRing Width="22" Height="22" IsIndeterminate="True" Margin="0,0,10,0"/>
                            <ui:TextBlock Text="Setting up the driver… This may take a few minutes" FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider between the display identity and its setup status -->
                    <Border Grid.Row="1" Height="1" Margin="0,14,0,14"
                            Background="{DynamicResource DividerStrokeColorDefaultBrush}"/>

                    <!-- Status line -->
                    <StackPanel Grid.Row="2">
                        <StackPanel Orientation="Horizontal">
                            <ui:TextBlock Text="Driver setup required" FontTypography="BodyStrong"
                                          VerticalAlignment="Center"/>
                            <ui:SymbolIcon Symbol="Warning24" FontSize="18" Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                        </StackPanel>
                        <ui:TextBlock Text="{Binding DriverSetupMessage}" FontTypography="Caption"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Display list -->
            <ScrollViewer Grid.Row="2" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0"
                          Focusable="False">
                <ItemsControl ItemsSource="{Binding Displays}" Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DisplayViewModel}">
                            <ui:Card Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Identity -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                                Margin="0,0,14,0" VerticalAlignment="Top"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                                            <ui:SymbolIcon Symbol="Desktop24" FontSize="24"
                                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <ui:TextBlock Text="{Binding ProductName}" FontTypography="BodyStrong"/>
                                            <TextBox Text="{Binding Subtitle, Mode=OneWay}"
                                                     Style="{StaticResource SerialTextBox}" IsTabStop="False"
                                                     Margin="-2,2,0,0"/>
                                        </StackPanel>
                                        <ui:Button Grid.Column="2" VerticalAlignment="Top" Margin="14,0,0,0"
                                                   Padding="6" Appearance="Secondary"
                                                   Click="OnOverflowMenuButtonClick"
                                                   Visibility="{Binding OverflowMenuVisibility}"
                                                   ToolTip="More options">
                                            <ui:Button.Icon>
                                                <ui:SymbolIcon Symbol="MoreHorizontal24"/>
                                            </ui:Button.Icon>
                                            <ui:Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Uninstall driver"
                                                              Command="{Binding PlacementTarget.DataContext.UninstallDriverCommand,
                                                                        RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                              ToolTip="Remove the WinUSB driver and revert this display to the default Windows driver. You can run setup again afterwards.">
                                                        <MenuItem.Icon>
                                                            <ui:SymbolIcon Symbol="PlugDisconnected24"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </ui:Button.ContextMenu>
                                        </ui:Button>
                                    </Grid>

                                    <!-- Brightness -->
                                    <Grid Grid.Row="1" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0" Symbol="BrightnessLow24" FontSize="18"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <Slider Grid.Column="1" Margin="12,0,12,0" Minimum="0" Maximum="100"
                                                IsSnapToTickEnabled="True" TickFrequency="1"
                                                IsEnabled="{Binding IsAvailable}"
                                                Value="{Binding BrightnessPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center"/>
                                        <ui:SymbolIcon Grid.Column="2" Symbol="BrightnessHigh24" FontSize="22"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBlock Grid.Column="3" Width="44" TextAlignment="Right"
                                                      VerticalAlignment="Center" FontTypography="BodyStrong"
                                                      Text="{Binding BrightnessPercent, StringFormat={}{0}%}"/>
                                    </Grid>

                                    <!-- Per-display error -->
                                    <ui:InfoBar Grid.Row="2" Margin="0,12,0,0" Severity="Error" IsClosable="False"
                                                Title="Brightness unavailable"
                                                Message="{Binding StatusText}"
                                                IsOpen="{Binding HasError}"/>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="320" Visibility="{Binding EmptyVisibility}">
                <ui:SymbolIcon Symbol="Desktop24" FontSize="40" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                <ui:TextBlock Text="No Apple display detected" FontTypography="BodyStrong"
                              HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <ui:TextBlock TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              FontTypography="Caption" Margin="0,4,0,0"
                              Text="Connect a Studio Display or Pro Display XDR over USB-C / Thunderbolt, then click Refresh."/>
            </StackPanel>

            <!-- Footer -->
            <ui:TextBlock Grid.Row="3" Margin="0,12,0,0" HorizontalAlignment="Right"
                          Text="Closing keeps NitTray in the system tray."
                          FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
