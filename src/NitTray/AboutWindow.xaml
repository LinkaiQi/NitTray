<ui:FluentWindow x:Class="NitTray.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:NitTray.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="About NitTray"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance vm:AboutViewModel}">

    <ui:FluentWindow.Resources>
        <!-- Official Buy Me a Coffee brand button: brand yellow with dark content and
             rounded corners, rendered natively so it stays crisp at any DPI. -->
        <Style x:Key="BmcButton" TargetType="Button">
            <Setter Property="Background" Value="#FFDD00"/>
            <Setter Property="Foreground" Value="#0D0C22"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFD400"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F2C900"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small accent-coloured text link. -->
        <Style x:Key="TextLink" TargetType="ui:Button">
            <Setter Property="Appearance" Value="Transparent"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="About NitTray"
                     ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon-32.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="26,8,26,22">

            <!-- App identity -->
            <Image Source="pack://application:,,,/Assets/AppIcon-256.png"
                   Width="72" Height="72" HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <ui:TextBlock Text="{Binding AppName}" FontTypography="TitleLarge"
                          HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <ui:TextBlock Text="{Binding VersionText}" FontTypography="Body"
                          HorizontalAlignment="Center" Margin="0,3,0,0"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ui:TextBlock Text="{Binding Tagline}" FontTypography="Body"
                          HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                          Margin="0,8,0,0"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <Border Height="1" Margin="0,20"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>

            <!-- Supported displays -->
            <ui:TextBlock Text="Supported Displays" FontTypography="BodyStrong"
                          HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding SupportedDisplays}" Focusable="False"
                          HorizontalAlignment="Center">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="12.5" TextAlignment="Center" Margin="0,2"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Height="1" Margin="0,20"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>

            <!-- Donate -->
            <Button Style="{StaticResource BmcButton}" HorizontalAlignment="Center"
                    Tag="{Binding DonateUrl}" Click="OnLinkClick">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="DrinkCoffee24" FontSize="18" Foreground="#0D0C22"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Buy me a coffee" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Links -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                <ui:Button Style="{StaticResource TextLink}" Content="GitHub"
                           Tag="{Binding RepositoryUrl}" Click="OnLinkClick"/>
                <TextBlock Text="·" VerticalAlignment="Center" Margin="6,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                <ui:Button Style="{StaticResource TextLink}" Content="Check for Updates"
                           Tag="{Binding ReleasesUrl}" Click="OnLinkClick"/>
            </StackPanel>
            <ui:TextBlock Text="{Binding OpenSourceText}" FontTypography="Caption"
                          HorizontalAlignment="Center" Margin="0,8,0,0"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

            <!-- Legal -->
            <ui:TextBlock Text="{Binding LegalText}" FontTypography="Caption" TextWrapping="Wrap"
                          TextAlignment="Center" MaxWidth="320" HorizontalAlignment="Center" Margin="0,20,0,0"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

            <!-- Footer -->
            <ui:TextBlock Text="{Binding FooterText}" FontTypography="Caption"
                          HorizontalAlignment="Center" Margin="0,14,0,0"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
