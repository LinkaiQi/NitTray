<ui:FluentWindow x:Class="NitTray.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:NitTray.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="About NitTray"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ShowInTaskbar="False"
        d:DataContext="{d:DesignInstance vm:AboutViewModel}">

    <ui:FluentWindow.Resources>
        <!-- A transparent, full-width row used for the resource/support links. -->
        <Style x:Key="LinkRow" TargetType="ui:Button">
            <Setter Property="Appearance" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="About NitTray"
                     ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon-32.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="24,6,24,20">

            <!-- App identity -->
            <StackPanel Orientation="Horizontal">
                <Image Source="pack://application:,,,/Assets/AppIcon-256.png"
                       Width="64" Height="64" VerticalAlignment="Top"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <ui:TextBlock Text="{Binding AppName}" FontTypography="TitleLarge"/>
                    <ui:TextBlock Text="{Binding VersionText}" FontTypography="Body" Margin="0,2,0,0"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:TextBlock Text="{Binding Tagline}" TextWrapping="Wrap" MaxWidth="300"
                                  FontTypography="Body" Margin="0,6,0,0" HorizontalAlignment="Left"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Supported displays -->
            <ui:TextBlock Text="SUPPORTED DISPLAYS" FontTypography="Caption" Margin="2,22,0,8"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            <ui:Card Padding="4">
                <ItemsControl ItemsSource="{Binding SupportedDisplays}" Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10,7,10,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" CornerRadius="4" Padding="7,1"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                    <TextBlock Text="{Binding ProductId}" FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ui:Card>

            <!-- Project & resources -->
            <ui:TextBlock Text="PROJECT &amp; RESOURCES" FontTypography="Caption" Margin="2,22,0,8"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            <ui:Card Padding="4">
                <StackPanel>
                    <ui:Button Style="{StaticResource LinkRow}" Tag="{Binding RepositoryUrl}" Click="OnLinkClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="BranchFork24" FontSize="18" Margin="0,0,12,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBlock Grid.Column="1" Text="GitHub repository" VerticalAlignment="Center"/>
                            <ui:SymbolIcon Grid.Column="2" Symbol="ArrowUpRight24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </ui:Button>
                    <ui:Button Style="{StaticResource LinkRow}" Tag="{Binding ReleasesUrl}" Click="OnLinkClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="ArrowSync24" FontSize="18" Margin="0,0,12,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBlock Grid.Column="1" Text="Check for updates" VerticalAlignment="Center"/>
                            <ui:SymbolIcon Grid.Column="2" Symbol="ArrowUpRight24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </ui:Button>
                    <ui:Button Style="{StaticResource LinkRow}" Tag="{Binding IssuesUrl}" Click="OnLinkClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Bug24" FontSize="18" Margin="0,0,12,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBlock Grid.Column="1" Text="Report an issue" VerticalAlignment="Center"/>
                            <ui:SymbolIcon Grid.Column="2" Symbol="ArrowUpRight24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </ui:Button>
                    <ui:Button Style="{StaticResource LinkRow}" Tag="{Binding LicenseUrl}" Click="OnLinkClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Scales24" FontSize="18" Margin="0,0,12,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBlock Grid.Column="1" Text="License — GPL-3.0" VerticalAlignment="Center"/>
                            <ui:SymbolIcon Grid.Column="2" Symbol="ArrowUpRight24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </ui:Button>
                    <ui:Button Style="{StaticResource LinkRow}" Tag="{Binding ThirdPartyNoticesUrl}" Click="OnLinkClick">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="DocumentBulletList24" FontSize="18" Margin="0,0,12,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBlock Grid.Column="1" Text="Third-party notices" VerticalAlignment="Center"/>
                            <ui:SymbolIcon Grid.Column="2" Symbol="ArrowUpRight24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

            <!-- Support -->
            <ui:TextBlock Text="SUPPORT DEVELOPMENT" FontTypography="Caption" Margin="2,22,0,8"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            <ui:Button Appearance="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                       Padding="0,10" Content="Buy me a coffee" Cursor="Hand"
                       Tag="{Binding DonateUrl}" Click="OnLinkClick">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="DrinkCoffee24"/>
                </ui:Button.Icon>
            </ui:Button>

            <!-- Legal -->
            <ui:TextBlock Text="{Binding LegalText}" TextWrapping="Wrap" FontTypography="Caption" Margin="0,20,0,0"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

            <!-- Footer -->
            <ui:TextBlock Text="{Binding FooterText}" FontTypography="Caption" HorizontalAlignment="Center"
                          Margin="0,14,0,0"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
