<Window x:Class="DisplayDial.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DisplayDial.ViewModels"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="DisplayDial — Apple Studio Display"
        Width="540" Height="460" MinWidth="440" MinHeight="320"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#F4F4F6"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    Padding="12,5" MinWidth="80"/>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Connected Displays" FontSize="20" FontWeight="SemiBold" Foreground="#202024"/>
                <TextBlock Text="Apple Studio Display and Pro Display XDR — drag a slider to set brightness." FontSize="11" Foreground="#6E6E73" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <ItemsControl ItemsSource="{Binding Displays}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DisplayViewModel}">
                            <Border BorderBrush="#D8D8DC" BorderThickness="1" CornerRadius="8"
                                    Padding="14" Margin="0,0,0,10" Background="#FFFFFF">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="{Binding ProductName}"
                                               FontSize="14" FontWeight="SemiBold" Foreground="#202024"/>
                                    <TextBlock Grid.Row="1" Text="{Binding SerialDescription}"
                                               Foreground="#6E6E73" FontSize="11" Margin="0,3,0,0"
                                               TextTrimming="CharacterEllipsis"/>

                                    <DockPanel Grid.Row="2" Margin="0,14,0,0" LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Left" Text="Brightness" VerticalAlignment="Center"
                                                   Foreground="#3A3A3D"/>
                                        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                                   Width="44" TextAlignment="Right"
                                                   Foreground="#202024"
                                                   Text="{Binding BrightnessPercent, StringFormat={}{0}%}"/>
                                        <Slider Margin="14,0,14,0" Minimum="0" Maximum="100"
                                                IsSnapToTickEnabled="True" TickFrequency="1"
                                                IsEnabled="{Binding IsAvailable}"
                                                Value="{Binding BrightnessPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="3" Text="{Binding StatusText}" Foreground="#A1A1A6"
                                               FontSize="10" Margin="0,6,0,0"
                                               Visibility="{Binding StatusVisibility}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding EmptyVisibility}">
                <TextBlock Text="No Apple display detected." FontSize="14" Foreground="#6E6E73"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Plug in an Apple Studio Display or Pro Display XDR over USB-C / Thunderbolt and click Refresh."
                           FontSize="11" Foreground="#A1A1A6" Margin="0,4,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="True">
            <TextBlock DockPanel.Dock="Right" Text="Close to keep DisplayDial in the system tray."
                       Foreground="#A1A1A6" FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#6E6E73" FontSize="11"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </DockPanel>
    </Grid>
</Window>
